{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "packages/core": {
      "release-type": "node",
      "component": "core",
      "extra-files": [
        {
          "type": "json",
          "path": "/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "packages/mcp-server": {
      "release-type": "node",
      "component": "mcp-server",
      "extra-files": [
        {
          "type": "generic",
          "path": "src/index.ts"
        }
      ]
    }
  }
}
